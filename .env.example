# Copy this file to .env and fill in your actual token.
# The .env file is gitignored — never commit it.
#
# To generate a token:
#   1. Log in to https://www.licor.cloud/
#   2. Go to Data > API > Add Token
#   3. Name it (e.g., "sensortower-daily-pull") and copy the value
#
# For GitHub Actions, also add the token as a repository secret named LICOR_TOKEN
# (Settings > Secrets and variables > Actions > New repository secret).

LICOR_TOKEN=your_licor_cloud_api_token_here
LICOR_DEVICE_SN=22411541
